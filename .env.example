# GEMINI_API_KEY: Required for Gemini AI API calls.
# RJT NEXUS360 reads this at runtime from environment secrets.
# Configure this only in local .env or deployment secrets.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# Public application URL used for self-referential links, callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# Turso/LibSQL database connection. Keep real values only in .env or Vercel.
TURSO_DATABASE_URL="libsql://YOUR_DATABASE.turso.io"
TURSO_AUTH_TOKEN="YOUR_TURSO_AUTH_TOKEN"
